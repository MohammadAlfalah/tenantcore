# Copy to .env and adjust for your environment. docker-compose has built-in defaults, so this is
# optional for local use — but you MUST set a strong JWT_SECRET for anything non-local.

# --- Database ---
POSTGRES_USER=tenantcore
POSTGRES_PASSWORD=tenantcore
POSTGRES_DB=tenantcore
DB_PORT=5432

# --- API ---
API_PORT=8080
# Must be at least 32 characters. Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_super_secret_dev_signing_key_at_least_32_chars_long
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# --- Frontend ---
FRONTEND_PORT=3000
